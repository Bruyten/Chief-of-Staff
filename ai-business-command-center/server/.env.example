# =========================================================================
#  CHIEF OF STAFF — Server environment variables
#  Copy this file to .env (server/.env) for local dev. Never commit .env.
#  In production: set these in your Render dashboard → Environment tab.
# =========================================================================

# -- Database --------------------------------------------------------------
# Local dev (Postgres via Docker / Supabase / Neon — anything Postgres):
DATABASE_URL="postgresql://user:password@localhost:5432/chief"

# -- Auth ------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-string-min-32-chars"
JWT_EXPIRES_IN="7d"

# -- AI --------------------------------------------------------------------
# Leave OPENAI_API_KEY empty during early dev — server runs in FAKE_AI mode
# and returns canned example outputs so you can build the whole app for $0.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
FAKE_AI="true"            # "true" = no real OpenAI call; "false" = use it

# -- HTTP ------------------------------------------------------------------
PORT="4000"
NODE_ENV="development"
CLIENT_ORIGIN="http://localhost:5173"   # your Vite dev URL

# -- Stripe billing (Phase 2) ----------------------------------------------
# Leave STRIPE_SECRET_KEY empty + FAKE_STRIPE=true to develop with no Stripe account.
# When you're ready: create products + prices in Stripe dashboard, paste the IDs below.
FAKE_STRIPE="true"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs (created in your Stripe dashboard)
STRIPE_PRICE_STARTER=""        # e.g. price_1Q…  ($19/mo, 100 generations)
STRIPE_PRICE_PRO=""             # e.g. price_1Q…  ($49/mo, 500 generations)
STRIPE_PRICE_AGENCY=""          # e.g. price_1Q…  ($99/mo, 2000 generations)

# After Checkout, Stripe redirects the user back here.
BILLING_SUCCESS_URL="http://localhost:5173/?billing=success"
BILLING_CANCEL_URL="http://localhost:5173/?billing=cancel"
