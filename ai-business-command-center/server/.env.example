# ============================================================================
# DIGITAL MARKETING CHIEF OF STAFF — SERVER ENVIRONMENT VARIABLES
# Copy this file to server/.env for local development.
# Never commit real .env files.
# ============================================================================

# ---------------------------------------------------------------------------
# Core runtime
# ---------------------------------------------------------------------------
NODE_ENV="development"
PORT="4000"

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/chief"

# ---------------------------------------------------------------------------
# Authentication
# Generate a long secure value, for example:
# openssl rand -hex 32
# ---------------------------------------------------------------------------
JWT_SECRET="change-me-to-a-long-random-string-min-32-chars"
JWT_EXPIRES_IN="7d"

# ---------------------------------------------------------------------------
# Frontend / CORS
# CLIENT_ORIGIN is the main app URL.
# CORS_ORIGINS supports comma-separated extra allowed origins.
# ---------------------------------------------------------------------------
CLIENT_ORIGIN="http://localhost:5173"
CORS_ORIGINS=""

# ---------------------------------------------------------------------------
# AI text generation
# FAKE_AI=true avoids paid AI calls in local development.
# ---------------------------------------------------------------------------
FAKE_AI="true"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ---------------------------------------------------------------------------
# Stripe billing
# FAKE_STRIPE=true keeps billing mocked while developing locally.
# ---------------------------------------------------------------------------
FAKE_STRIPE="true"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_AGENCY=""

BILLING_SUCCESS_URL="http://localhost:5173/?billing=success"
BILLING_CANCEL_URL="http://localhost:5173/?billing=cancel"

# ---------------------------------------------------------------------------
# Video provider architecture
# Keep VIDEO_PROVIDER=mock until a real provider is implemented.
# ---------------------------------------------------------------------------
VIDEO_PROVIDER="mock"
VIDEO_PROVIDER_API_KEY=""
VIDEO_PROVIDER_BASE_URL=""
VIDEO_PROVIDER_WEBHOOK_SECRET=""
VIDEO_MOCK_COMPLETED_URL=""
VIDEO_POLL_BATCH_SIZE="10"
