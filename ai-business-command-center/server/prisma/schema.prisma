generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  passwordHash          String
  name                  String?
  role                  String                 @default("user")
  plan                  String                 @default("free")
  credits               Int                    @default(5)
  creditsMax            Int                    @default(5)
  videoCredits          Int                    @default(0)
  videoCreditsMax       Int                    @default(0)
  stripeCustomerId      String?                @unique
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  projects              Project[]
  outputs               Output[]
  tasks                 Task[]
  subscription          Subscription?
  brandVoiceProfiles    BrandVoiceProfile[]
  chatConversations     ChatConversation[]
  workflowRuns          WorkflowRun[]
  automations           Automation[]
  automationRuns        AutomationRun[]
  videoJobs             VideoJob[]
  usageLedgerEntries    UsageLedgerEntry[]
  productLibraryItems   ProductLibraryItem[]

  @@index([role])
}

model Subscription {
  id                  String   @id @default(cuid())
  userId              String   @unique
  stripeSubscriptionId String   @unique
  stripePriceId       String
  plan                String
  status              String
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  cancelAtPeriodEnd   Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeSubscriptionId])
}

model Project {
  id                    String                 @id @default(cuid())
  userId                String
  name                  String
  niche                 String?
  brandVoice            String?
  emoji                 String?
  campaignGoal          String?
  targetAudience        String?
  offer                 String?
  campaignStatus        String?                @default("planning")
  launchDate            DateTime?
  brandVoiceProfileId   String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandVoiceProfile     BrandVoiceProfile?     @relation(fields: [brandVoiceProfileId], references: [id], onDelete: SetNull)
  products              Product[]
  outputs               Output[]
  tasks                 Task[]
  chatConversations     ChatConversation[]
  workflowRuns          WorkflowRun[]
  automations           Automation[]
  automationRuns        AutomationRun[]
  videoJobs             VideoJob[]

  @@index([userId])
  @@index([brandVoiceProfileId])
  @@index([campaignStatus])
}

model Product {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String
  audience    String?
  painPoint   String?
  benefits    String?
  price       String?
  offerType   String?
  cta         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  outputs     Output[]

  @@index([projectId])
}

model ProductLibraryItem {
  id                 String   @id @default(cuid())
  userId             String
  name               String
  productType        String
  revenueLane        String?
  description        String?
  targetAudience     String?
  painPoints         String?
  benefits           String?
  keywords           String?
  tags               String?
  offer              String?
  cta                String?
  priceRange         String?
  productUrl         String?
  coverImageUrl      String?
  promotionPriority  Int      @default(3)
  status             String   @default("active")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productType])
  @@index([revenueLane])
  @@index([status])
  @@index([promotionPriority])
}

model Output {
  id                    String            @id @default(cuid())
  userId                String
  projectId             String?
  productId             String?
  type                  String
  title                 String
  content               String
  inputSnapshot         Json
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  project               Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  product               Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  workflowSteps         WorkflowRunStep[]
  automationRuns        AutomationRun[]
  sourceVideoJobs       VideoJob[]        @relation("VideoJobSourceOutput")

  @@index([userId])
  @@index([projectId])
  @@index([productId])
  @@index([type])
}

model Task {
  id          String   @id @default(cuid())
  userId      String
  projectId   String?
  type        String
  status      String
  input       Json
  result      Json?
  tokensUsed  Int      @default(0)
  errorMsg    String?
  createdAt   DateTime @default(now())
  completedAt DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([status])
}

model BrandVoiceProfile {
  id                    String              @id @default(cuid())
  userId                String
  brandName             String
  businessType          String?
  targetAudience        String?
  primaryOffer          String?
  toneOfVoice           String?
  valueProposition      String?
  preferredCtas         String?
  bannedPhrases         String?
  differentiators       String?
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects              Project[]
  chatConversations     ChatConversation[]
  workflowRuns          WorkflowRun[]
  automations           Automation[]
  automationRuns        AutomationRun[]

  @@index([userId])
}

model ChatConversation {
  id                    String             @id @default(cuid())
  userId                String
  projectId             String?
  brandVoiceProfileId   String?
  title                 String?
  archivedAt            DateTime?
  lastMessageAt         DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  project               Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  brandVoiceProfile     BrandVoiceProfile? @relation(fields: [brandVoiceProfileId], references: [id], onDelete: SetNull)
  messages              ChatMessage[]

  @@index([userId])
  @@index([projectId])
  @@index([brandVoiceProfileId])
  @@index([archivedAt])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  role           String
  content        String
  tokensUsed     Int              @default(0)
  model          String?
  metadata       Json?
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
}

model WorkflowRun {
  id                    String              @id @default(cuid())
  userId                String
  projectId             String?
  brandVoiceProfileId   String?
  templateId            String
  title                 String
  status                String
  input                 Json
  summary               String?
  creditsSpent          Int                 @default(0)
  startedAt             DateTime            @default(now())
  completedAt           DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  project               Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  brandVoiceProfile     BrandVoiceProfile?  @relation(fields: [brandVoiceProfileId], references: [id], onDelete: SetNull)
  steps                 WorkflowRunStep[]
  automationRuns        AutomationRun[]
  sourceVideoJobs       VideoJob[]          @relation("VideoJobSourceWorkflowRun")

  @@index([userId])
  @@index([projectId])
  @@index([brandVoiceProfileId])
  @@index([templateId])
  @@index([status])
}

model WorkflowRunStep {
  id             String       @id @default(cuid())
  workflowRunId  String
  outputId       String?
  stepKey        String
  stepLabel      String
  skill          String
  status         String
  input          Json
  content        String?
  tokensUsed     Int          @default(0)
  errorMsg       String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  workflowRun    WorkflowRun  @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  output         Output?      @relation(fields: [outputId], references: [id], onDelete: SetNull)

  @@index([workflowRunId])
  @@index([outputId])
  @@index([status])
}

model Automation {
  id                    String               @id @default(cuid())
  userId                String
  projectId             String?
  brandVoiceProfileId   String?
  name                  String
  type                  String
  cadence               String
  enabled               Boolean              @default(true)
  timezone              String
  dayOfWeek             Int?
  dayOfMonth            Int?
  hour                  Int
  minute                Int
  config                Json
  lastRunAt             DateTime?
  nextRunAt             DateTime?
  lastStatus            String?
  lastError             String?
  failureCount          Int                  @default(0)
  lockedUntil           DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  project               Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  brandVoiceProfile     BrandVoiceProfile?   @relation(fields: [brandVoiceProfileId], references: [id], onDelete: SetNull)
  runs                  AutomationRun[]

  @@index([userId])
  @@index([projectId])
  @@index([brandVoiceProfileId])
  @@index([enabled])
  @@index([nextRunAt])
}

model AutomationRun {
  id                    String              @id @default(cuid())
  automationId          String
  userId                String
  projectId             String?
  brandVoiceProfileId   String?
  workflowRunId         String?
  outputId              String?
  type                  String
  trigger               String
  status                String
  creditsRequired       Int                 @default(0)
  creditsSpent          Int                 @default(0)
  result                Json?
  errorMsg              String?
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  automation            Automation          @relation(fields: [automationId], references: [id], onDelete: Cascade)
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  project               Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  brandVoiceProfile     BrandVoiceProfile?  @relation(fields: [brandVoiceProfileId], references: [id], onDelete: SetNull)
  workflowRun           WorkflowRun?        @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  output                Output?             @relation(fields: [outputId], references: [id], onDelete: SetNull)

  @@index([automationId])
  @@index([userId])
  @@index([projectId])
  @@index([workflowRunId])
  @@index([outputId])
  @@index([status])
}

model VideoJob {
  id                      String       @id @default(cuid())
  userId                  String
  projectId               String?
  sourceOutputId          String?
  sourceWorkflowRunId     String?
  title                   String
  sourceType              String
  useCase                 String
  aspectRatio             String
  durationSeconds         Int
  toneStyle               String
  cta                     String?
  promptBrief             String
  provider                String
  externalJobId           String?
  providerStatus          String?
  providerPayload         Json?
  status                  String
  errorMsg                String?
  videoUrl                String?
  thumbnailUrl            String?
  submittedAt             DateTime?
  completedAt             DateTime?
  failedAt                DateTime?
  pollAttempts            Int          @default(0)
  lastPolledAt            DateTime?
  nextPollAt              DateTime?
  lockedUntil             DateTime?
  creditChargedAt         DateTime?
  creditRefundedAt        DateTime?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  user                    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  project                 Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sourceOutput            Output?      @relation("VideoJobSourceOutput", fields: [sourceOutputId], references: [id], onDelete: SetNull)
  sourceWorkflowRun       WorkflowRun? @relation("VideoJobSourceWorkflowRun", fields: [sourceWorkflowRunId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([sourceOutputId])
  @@index([sourceWorkflowRunId])
  @@index([status])
  @@index([nextPollAt])
}

model UsageLedgerEntry {
  id              String   @id @default(cuid())
  userId          String
  bucket          String
  action          String
  amount          Int
  reason          String
  referenceType   String?
  referenceId     String?
  metadata        Json?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([bucket])
  @@index([action])
  @@index([referenceType, referenceId])
}

model WebhookEventReceipt {
  id                String   @id @default(cuid())
  provider          String
  externalEventId   String
  status            String
  errorMsg          String?
  processedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, externalEventId], name: "provider_externalEventId")
  @@index([status])
}
